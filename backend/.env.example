PORT=5050
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.thiv8bo.mongodb.net/expense-voucher-db?appName=Cluster0
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:5173

# Resend Email Configuration (Fallback)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=ExpenseVoucher <onboarding@resend.dev>

# Nodemailer SMTP Configuration (Primary - No custom domain needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_EMAIL=ExpenseVoucher <your_email@gmail.com>
